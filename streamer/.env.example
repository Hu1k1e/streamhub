# Streamer Environment Variables
# Copy this file to .env and fill in your values.
# This file is safe to commit to GitHub.

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=6987

# ── Storage ────────────────────────────────────────────────────────────────────
# Primary download directory (on a fast drive).
# Leave blank to use WebTorrent's default temp directory.
DEFAULT_DL_PATH=

# Fallback directory for files larger than LARGE_FILE_THRESHOLD_GB
# or when the primary drive is low on space.
FALLBACK_DL_PATH=D:\TempMovies

# Files larger than this (in GB) will use FALLBACK_DL_PATH
LARGE_FILE_THRESHOLD_GB=20

# ── WebTorrent ─────────────────────────────────────────────────────────────────
# Maximum simultaneous peer connections per torrent
MAX_CONNS=30

# Fixed ports for WebTorrent (avoid conflicts on restart)
DHT_PORT=6988
TORRENT_PORT=6989

# Maximum number of torrents kept in memory at once.
# Oldest unused torrent is evicted when this limit is reached.
MAX_ACTIVE_TORRENTS=5

# Recreate WebTorrent client after this many minutes of inactivity.
# Flushes stale peers and half-open sockets.
IDLE_RESET_MINUTES=15

# ── Cleanup ────────────────────────────────────────────────────────────────────
# How long (ms) an idle torrent is kept before being destroyed.
# Default: 300000 (5 minutes)
CLEANUP_DELAY_MS=300000

# Remove download folders older than this many hours on startup.
STARTUP_CLEANUP_AGE_HOURS=12

# ── Logging ────────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO
